public interface IVoar
{
    void Voar();
}

public interface INadar
{
    void Nadar();
}

public class Pato : INadar , IVoar
{
    public void Nadar()
    {
        Console.WriteLine("Nadando");
    }

    public void Voar()
    {
        Console.WriteLine("Voando");    
    }
}

public class Aguia : IVoar
{
    public void Voar()
    {
        Console.WriteLine("Voando");
    }
}

public class Program
{
    public static void Main()
    {
        Aguia a = new Aguia();
        a.Voar();

        Pato p = new Pato();
        p.Voar();
        p.Nadar();
    }
}
